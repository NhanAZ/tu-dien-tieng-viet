{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/origin-fact.schema.json",
  "title": "OriginFact",
  "type": "object",
  "additionalProperties": false,
  "required": ["origin_id", "word", "headword_normalized", "origin", "method", "source", "confidence", "review_status", "provenance"],
  "properties": {
    "origin_id": { "type": "string", "pattern": "^origin-" },
    "word": { "type": "string", "minLength": 1 },
    "headword_normalized": { "type": "string", "minLength": 1 },
    "origin": { "type": "string", "enum": ["thuần Việt", "Hán Việt", "vay mượn khác", "không rõ"] },
    "method": { "const": "normalized-source-origin-inference" },
    "source": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "review_status": { "type": "string", "enum": ["unreviewed", "machine-checked", "human-reviewed"] },
    "provenance": { "$ref": "#/$defs/sourceTrace" }
  },
  "$defs": {
    "sourceTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "source_entry_id", "source_revision", "raw_record_hash", "confidence", "review_status"],
      "properties": {
        "source_id": { "type": "string", "minLength": 1 },
        "source_entry_id": { "type": ["string", "null"] },
        "source_revision": { "type": ["string", "null"] },
        "raw_record_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "review_status": { "type": "string", "enum": ["unreviewed", "machine-checked", "human-reviewed"] }
      }
    }
  }
}
