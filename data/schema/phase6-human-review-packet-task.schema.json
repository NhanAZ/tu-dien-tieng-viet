{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/phase6-human-review-packet-task.schema.json",
  "title": "Phase6HumanReviewPacketTask",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "task_type",
    "headword_normalized",
    "words",
    "review_status",
    "allowed_decisions",
    "review_fields",
    "evidence_links",
    "evidence"
  ],
  "properties": {
    "task_id": { "type": "string", "pattern": "^phase6-review-" },
    "task_type": {
      "type": "string",
      "enum": ["pronunciation_conflict_review", "dialect_label_review"]
    },
    "headword_normalized": { "type": "string", "minLength": 1 },
    "words": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "review_status": { "const": "unreviewed" },
    "allowed_decisions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "review_fields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "selected_display_ipa",
        "selected_dialect",
        "qualifier_note",
        "reviewer_id",
        "reviewer_notes",
        "reviewed_at"
      ],
      "properties": {
        "decision": { "type": "null" },
        "selected_display_ipa": { "type": "null" },
        "selected_dialect": { "type": "null" },
        "qualifier_note": { "const": "" },
        "reviewer_id": { "const": "" },
        "reviewer_notes": { "const": "" },
        "reviewed_at": { "const": "" }
      }
    },
    "evidence_links": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "path", "key"],
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "key": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence": { "type": "object" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "task_type": { "const": "pronunciation_conflict_review" } },
        "required": ["task_type"]
      },
      "then": {
        "properties": {
          "allowed_decisions": {
            "const": [
              "keep_all_source_attested_variants",
              "select_one_display_ipa",
              "split_by_source_entry_or_pos",
              "requires_parser_followup",
              "insufficient_evidence"
            ]
          },
          "evidence": { "$ref": "#/$defs/pronunciationConflictEvidence" }
        }
      }
    },
    {
      "if": {
        "properties": { "task_type": { "const": "dialect_label_review" } },
        "required": ["task_type"]
      },
      "then": {
        "properties": {
          "allowed_decisions": {
            "const": [
              "assign_recognized_dialect",
              "split_label_and_qualifier",
              "not_a_dialect_label",
              "leave_dialect_null",
              "insufficient_evidence"
            ]
          },
          "evidence": { "$ref": "#/$defs/dialectLabelEvidence" }
        }
      }
    }
  ],
  "$defs": {
    "stringSet": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "pronunciationConflictEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conflict_id",
        "reason_tags",
        "entry_scope_reasons",
        "review_route",
        "route_rationale",
        "internal_groups",
        "recommended_action"
      ],
      "properties": {
        "conflict_id": { "type": "string", "pattern": "^pronunciation-conflict-" },
        "reason_tags": { "$ref": "#/$defs/stringSet" },
        "entry_scope_reasons": { "$ref": "#/$defs/stringSet" },
        "review_route": { "type": "string", "enum": ["parser_fix", "human_review"] },
        "route_rationale": { "type": "string", "minLength": 1 },
        "internal_groups": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object" }
        },
        "recommended_action": { "type": "string", "minLength": 1 }
      }
    },
    "dialectLabelEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pronunciation_id",
        "source",
        "source_entry_id",
        "raw_record_hash",
        "source_tags",
        "source_note",
        "gap_reason",
        "review_route",
        "recommended_action"
      ],
      "properties": {
        "pronunciation_id": { "type": "string", "pattern": "^pronunciation-" },
        "source": { "type": "string", "minLength": 1 },
        "source_entry_id": { "type": ["string", "null"] },
        "raw_record_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "source_tags": { "$ref": "#/$defs/stringSet" },
        "source_note": { "type": ["string", "null"] },
        "gap_reason": {
          "type": "string",
          "enum": [
            "recognized_geographic_label_with_qualifier",
            "unrecognized_explicit_note",
            "unrecognized_explicit_tag"
          ]
        },
        "review_route": {
          "type": "string",
          "enum": ["manual_label_parsing_review", "manual_label_review"]
        },
        "recommended_action": { "type": "string", "minLength": 1 }
      }
    }
  }
}
