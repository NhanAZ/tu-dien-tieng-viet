{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/entity-candidate.schema.json",
  "title": "EntityCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_id",
    "cluster_id",
    "candidate_scope",
    "parent_cluster_status",
    "word",
    "entity_type",
    "definition_count",
    "sources",
    "risk_tags",
    "reasons",
    "canonical_definition",
    "source_definitions"
  ],
  "properties": {
    "entity_id": { "type": "string", "pattern": "^entity-" },
    "cluster_id": { "type": "string", "pattern": "^cluster-" },
    "candidate_scope": { "type": "string", "enum": ["cluster", "member"] },
    "parent_cluster_status": {
      "type": "string",
      "enum": [
        "auto_accepted",
        "machine_clustered",
        "machine_retained",
        "needs_review",
        "quarantined",
        "entity_or_encyclopedic",
        "reference_non_vi"
      ]
    },
    "word": { "type": "string", "minLength": 1 },
    "entity_type": {
      "type": "string",
      "enum": [
        "proper_name",
        "place_name",
        "domain_or_encyclopedic",
        "punctuation_headword",
        "mixed_entity_or_encyclopedic"
      ]
    },
    "definition_count": { "type": "integer", "minimum": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "risk_tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "canonical_definition": { "$ref": "#/$defs/sourceDefinition" },
    "source_definitions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceDefinition" }
    }
  },
  "$defs": {
    "sourceDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sense_id",
        "definition_uid",
        "entry_id",
        "source",
        "source_entry_id",
        "raw_record_hash",
        "language",
        "review_status",
        "definition_index",
        "confidence",
        "risk_tags",
        "meaning"
      ],
      "properties": {
        "sense_id": { "type": "string", "pattern": "^sense-" },
        "definition_uid": { "type": "string", "pattern": "^def-" },
        "entry_id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "source_entry_id": { "type": ["string", "null"] },
        "raw_record_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "language": { "type": "string" },
        "review_status": {
          "type": "string",
          "enum": ["unreviewed", "machine-checked", "human-reviewed"]
        },
        "definition_index": { "type": "integer", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "risk_tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "meaning": { "type": "string", "minLength": 1 }
      }
    }
  }
}
