{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/han-character.schema.json",
  "title": "HanCharacterEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "character",
    "radical",
    "radical_stroke_count",
    "total_stroke_count",
    "readings_han_viet",
    "readings_nom",
    "writing_systems",
    "meanings",
    "compound_examples",
    "variant_forms",
    "sources"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^u\\+[0-9A-F]{4,6}$" },
    "character": { "type": "string", "minLength": 1 },
    "radical": { "type": ["string", "null"] },
    "radical_stroke_count": { "type": ["integer", "null"], "minimum": 1 },
    "total_stroke_count": { "type": ["integer", "null"], "minimum": 1 },
    "readings_han_viet": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "readings_nom": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "writing_systems": {
      "type": "array",
      "items": { "type": "string", "enum": ["Hán", "Nôm"] },
      "uniqueItems": true,
      "minItems": 1
    },
    "meanings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["meaning", "source", "language", "provenance"],
        "properties": {
          "meaning": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "language": { "type": "string", "enum": ["vi", "en", "other"] },
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_id", "source_entry_id", "source_revision", "raw_record_hash", "confidence", "review_status"],
            "properties": {
              "source_id": { "type": "string", "minLength": 1 },
              "source_entry_id": { "type": ["string", "null"] },
              "source_revision": { "type": ["string", "null"] },
              "raw_record_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "review_status": { "type": "string", "enum": ["unreviewed", "machine-checked", "human-reviewed"] }
            }
          }
        }
      }
    },
    "compound_examples": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "variant_forms": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "minItems": 1
    }
  }
}
