{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/phase6-ai-review-decision.schema.json",
  "title": "Phase6AiReviewDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "task_id",
    "task_type",
    "headword_normalized",
    "words",
    "reviewer_type",
    "review_status",
    "source_packet_status",
    "ai_review_version",
    "method",
    "decision",
    "confidence",
    "confidence_score",
    "recommended_human_priority",
    "requires_human_confirmation",
    "promotion_allowed",
    "rationale",
    "evidence_summary",
    "suggested_review_fields",
    "cautions"
  ],
  "properties": {
    "review_id": { "type": "string", "pattern": "^ai-review-" },
    "task_id": { "type": "string", "pattern": "^phase6-review-" },
    "task_type": {
      "type": "string",
      "enum": ["pronunciation_conflict_review", "dialect_label_review"]
    },
    "headword_normalized": { "type": "string", "minLength": 1 },
    "words": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "reviewer_type": { "const": "ai" },
    "review_status": { "const": "ai-reviewed" },
    "source_packet_status": { "const": "unreviewed" },
    "ai_review_version": { "const": "phase6-ai-review-v1" },
    "method": { "const": "conservative_source_attributed_triage" },
    "decision": {
      "type": "string",
      "enum": [
        "keep_all_source_attested_variants",
        "select_one_display_ipa",
        "split_by_source_entry_or_pos",
        "requires_parser_followup",
        "insufficient_evidence",
        "assign_recognized_dialect",
        "split_label_and_qualifier",
        "not_a_dialect_label",
        "leave_dialect_null"
      ]
    },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "recommended_human_priority": { "type": "string", "enum": ["high", "medium", "low"] },
    "requires_human_confirmation": { "const": true },
    "promotion_allowed": { "const": false },
    "rationale": { "type": "string", "minLength": 1 },
    "evidence_summary": { "type": "object" },
    "suggested_review_fields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "selected_display_ipa",
        "selected_dialect",
        "qualifier_note",
        "reviewer_notes"
      ],
      "properties": {
        "decision": { "type": "string", "minLength": 1 },
        "selected_display_ipa": { "type": "null" },
        "selected_dialect": { "type": ["string", "null"] },
        "qualifier_note": { "type": "string" },
        "reviewer_notes": { "type": "string", "minLength": 1 }
      }
    },
    "cautions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "task_type": { "const": "pronunciation_conflict_review" } },
        "required": ["task_type"]
      },
      "then": {
        "properties": {
          "decision": {
            "enum": [
              "keep_all_source_attested_variants",
              "select_one_display_ipa",
              "split_by_source_entry_or_pos",
              "requires_parser_followup",
              "insufficient_evidence"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "task_type": { "const": "dialect_label_review" } },
        "required": ["task_type"]
      },
      "then": {
        "properties": {
          "decision": {
            "enum": [
              "assign_recognized_dialect",
              "split_label_and_qualifier",
              "not_a_dialect_label",
              "leave_dialect_null",
              "insufficient_evidence"
            ]
          }
        }
      }
    }
  ]
}
