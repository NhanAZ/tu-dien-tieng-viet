{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/phase6-pronunciation-entry-scope-triage.schema.json",
  "title": "Phase6PronunciationEntryScopeTriage",
  "type": "object",
  "additionalProperties": false,
  "required": ["generatedAt", "status", "queueRows", "reasonCounts", "routeCounts", "files", "caveats"],
  "properties": {
    "generatedAt": { "type": "string", "minLength": 1 },
    "status": { "const": "PHASE6_PRONUNCIATION_ENTRY_SCOPE_TRIAGE_DRAFT" },
    "queueRows": { "type": "integer", "minimum": 0 },
    "reasonCounts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "routeCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parser_fix", "human_review"],
      "properties": {
        "parser_fix": { "type": "integer", "minimum": 0 },
        "human_review": { "type": "integer", "minimum": 0 }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": ["details", "sample"],
      "properties": {
        "details": { "const": "data/processed/phase6/pronunciation-unresolved-analysis.jsonl" },
        "sample": { "const": "data/processed/phase6/pronunciation-unresolved-analysis.sample.jsonl" }
      }
    },
    "caveats": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  }
}
