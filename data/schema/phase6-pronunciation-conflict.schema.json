{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/phase6-pronunciation-conflict.schema.json",
  "title": "Phase6PronunciationConflict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "conflict_id",
    "headword_normalized",
    "words",
    "bucket",
    "raw_ipa_values",
    "display_normalized_ipa_values",
    "safe_display_ipa",
    "sources",
    "dialects",
    "transcription_systems",
    "source_values",
    "fact_count",
    "metadata_gaps",
    "sample_fact_ids",
    "recommended_action"
  ],
  "properties": {
    "conflict_id": { "type": "string", "pattern": "^pronunciation-conflict-" },
    "headword_normalized": { "type": "string", "minLength": 1 },
    "words": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "bucket": { "type": "string", "enum": ["formatting_only", "dialect_source_variant", "source_attested_variant", "unresolved"] },
    "raw_ipa_values": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "display_normalized_ipa_values": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "safe_display_ipa": { "type": ["string", "null"] },
    "sources": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "dialects": { "type": "array", "minItems": 1, "items": { "type": ["string", "null"] }, "uniqueItems": true },
    "transcription_systems": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "source_values": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source",
          "dialect",
          "transcription_system",
          "fact_count",
          "raw_record_count",
          "raw_records_with_multiple_display_values",
          "raw_ipa_values",
          "display_normalized_ipa_values",
          "sample_fact_ids"
        ],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "dialect": { "type": ["string", "null"] },
          "transcription_system": { "type": "string", "minLength": 1 },
          "fact_count": { "type": "integer", "minimum": 1 },
          "raw_record_count": { "type": "integer", "minimum": 1 },
          "raw_records_with_multiple_display_values": { "type": "integer", "minimum": 0 },
          "raw_ipa_values": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "display_normalized_ipa_values": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "sample_fact_ids": { "type": "array", "minItems": 1, "maxItems": 10, "items": { "type": "string", "pattern": "^pronunciation-" }, "uniqueItems": true }
        }
      }
    },
    "fact_count": { "type": "integer", "minimum": 2 },
    "metadata_gaps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["facts_without_dialect"],
      "properties": {
        "facts_without_dialect": { "type": "integer", "minimum": 0 }
      }
    },
    "sample_fact_ids": { "type": "array", "minItems": 1, "maxItems": 20, "items": { "type": "string", "pattern": "^pronunciation-" }, "uniqueItems": true },
    "recommended_action": { "type": "string", "minLength": 1 }
  }
}
