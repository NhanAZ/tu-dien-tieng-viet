{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/phase6-pronunciation-dialect-coverage.schema.json",
  "title": "Phase6PronunciationDialectCoverage",
  "type": "object",
  "additionalProperties": false,
  "required": ["generatedAt", "status", "facts", "factsWithDialect", "factsWithoutDialect", "sources", "caveats"],
  "properties": {
    "generatedAt": { "type": "string", "minLength": 1 },
    "status": { "const": "PHASE6_PRONUNCIATION_DIALECT_COVERAGE_DRAFT" },
    "facts": { "type": "integer", "minimum": 0 },
    "factsWithDialect": { "type": "integer", "minimum": 0 },
    "factsWithoutDialect": { "type": "integer", "minimum": 0 },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceCoverage" },
      "uniqueItems": true
    },
    "caveats": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    }
  },
  "$defs": {
    "countMap": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "sourceCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "method", "facts", "facts_with_dialect", "facts_without_dialect", "dialect_counts", "unrecovered_reason"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "facts": { "type": "integer", "minimum": 0 },
        "facts_with_dialect": { "type": "integer", "minimum": 0 },
        "facts_without_dialect": { "type": "integer", "minimum": 0 },
        "dialect_counts": { "$ref": "#/$defs/countMap" },
        "unrecovered_reason": { "type": ["string", "null"] }
      }
    }
  }
}
