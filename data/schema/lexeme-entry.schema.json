{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/lexeme-entry.schema.json",
  "title": "VietnameseLexemeEntry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "headword", "headword_normalized", "headword_no_tone", "syllable_count", "language", "evidence"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "headword": { "type": "string", "minLength": 1 },
    "headword_normalized": { "type": "string", "minLength": 1 },
    "headword_no_tone": { "type": "string", "minLength": 1 },
    "syllable_count": { "type": "integer", "minimum": 1 },
    "language": { "const": "vi" },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "source_entry_id", "raw_record_hash"],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "source_entry_id": { "type": ["string", "null"] },
          "raw_record_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
