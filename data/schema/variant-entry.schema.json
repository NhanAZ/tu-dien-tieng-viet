{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/variant-entry.schema.json",
  "title": "VietnameseOrthographicVariantEntry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "key", "forms", "relation", "provenance"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "key": { "type": "string", "minLength": 1 },
    "forms": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "relation": { "const": "tone-placement" },
    "provenance": { "type": "array", "minItems": 1, "items": { "$ref": "word-entry.schema.json#/$defs/sourceTrace" } }
  }
}
