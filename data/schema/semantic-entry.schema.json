{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tu-dien-tieng-viet/schema/semantic-entry.schema.json",
  "title": "VietnameseSemanticEntry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "synset_id", "part_of_speech", "lemmas", "provenance"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "synset_id": { "type": "string", "pattern": "^[0-9]{8}-[asnvr]$" },
    "part_of_speech": { "type": "string", "enum": ["adjective", "adjective satellite", "adverb", "noun", "verb", "unknown"] },
    "lemmas": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "provenance": { "type": "array", "minItems": 1, "items": { "$ref": "word-entry.schema.json#/$defs/sourceTrace" } }
  }
}
